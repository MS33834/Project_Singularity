# Project Singularity — 环境变量示例
# 复制为 .env 并填入真实值：cp .env.example .env
# 注意：.env 文件已被 .gitignore 忽略，不会提交到仓库

# ComfyUI
COMFYUI_URL=http://127.0.0.1:8188

# 可灵 API
KLING_API_KEY=your_kling_api_key
KLING_BASE_URL=https://api.piapi.ai

# ElevenLabs 配音
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Suno 配乐
SUNO_API_KEY=your_suno_api_key
SUNO_BASE_URL=https://api.sunoaiapi.com

# Git 仓库同步（sync_repos.sh 使用，不要泄露）
GITHUB_TOKEN=your_github_token
GITCODE_TOKEN=your_gitcode_token
